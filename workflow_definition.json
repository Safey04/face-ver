{
  "version": "1.0",
  "inputs": [
    {
      "type": "InferenceImage",
      "name": "image"
    },
    {
      "type": "WorkflowParameter",
      "name": "confidence",
      "default_value": 0.5
    }
  ],
  "steps": [
    {
      "type": "roboflow_core/roboflow_object_detection_model@v2",
      "name": "face_detection",
      "images": "$inputs.image",
      "model_id": "face-detection-mik1i/5",
      "confidence": "$inputs.confidence"
    },
    {
      "type": "roboflow_core/dynamic_crop@v1",
      "name": "face_crop",
      "images": "$inputs.image",
      "predictions": "$steps.face_detection.predictions"
    },
    {
      "type": "roboflow_core/bounding_box_visualization@v1",
      "name": "bbox_visualization",
      "image": "$inputs.image",
      "predictions": "$steps.face_detection.predictions",
      "color": "#00FF00",
      "thickness": 2
    }
  ],
  "outputs": [
    {
      "type": "JsonField",
      "name": "face_crops",
      "selector": "$steps.face_crop.crops"
    },
    {
      "type": "JsonField",
      "name": "predictions",
      "selector": "$steps.face_detection.predictions"
    },
    {
      "type": "JsonField",
      "name": "annotated_image",
      "selector": "$steps.bbox_visualization.image"
    }
  ]
}
